# Diakonia App — variáveis de ambiente necessárias
# Copie este arquivo para .env e preencha com seus valores do Supabase
# Obtenha em: https://supabase.com/dashboard/project/SEU_PROJETO/settings/api

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ──────────────────────────────────────────────────────────────────────────────
# VITE_SUPABASE_SERVICE_ROLE_KEY — necessária para criar/resetar usuários
# ⚠️  Esta chave ignora o RLS. Nunca exponha em repositórios públicos.
# Obtenha em: Supabase Dashboard → Settings → API → "service_role" (secret)
# ──────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJ...
